generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  password  String
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  orders    Order[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  icon     String?
  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  price       Decimal
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  previewUrl  String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  orders      Order[]
}

enum ProjectStatus {
  PENDING_REQUIREMENTS
  IN_PROGRESS
  REVISION
  COMPLETED
}

model Order {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  status        OrderStatus   @default(PENDING)
  projectStatus ProjectStatus @default(PENDING_REQUIREMENTS)
  liveUrl       String?
  gateway       String        @default("SAFEPAY")
  sessionId     String?
  createdAt     DateTime      @default(now())
}

